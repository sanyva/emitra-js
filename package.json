{
  "name": "emitra-js",
  "version": "2.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run build:cdn",
    "build:cdn": "esbuild src/index.ts --bundle --minify --format=iife --global-name=Emitra --outfile=dist/emitra.min.js --footer:js=\"if(typeof window!=='undefined'){window.Emitra=Emitra.default||Emitra}\""
  },
  "keywords": [
    "websocket",
    "realtime",
    "emitra",
    "socket",
    "pubsub",
    "event-stream",
    "socket.io",
    "realtime-client",
    "websocket-client",
    "free websocket"
  ],
  "author": "sanyva@gmail.com",
  "license": "MIT",
  "dependencies": {
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  }
}
